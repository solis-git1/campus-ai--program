<view class="container">
  <!-- 用户信息 -->
  <view class="user-info card flex-between" bindtap="editProfile">
    <view class="user-left">
      <view class="avatar-placeholder">👤</view>
      <view>
        <text class="nickname">{{userInfo.nickname || '用户'}}</text>
        <text class="user-id">学号：{{userInfo.username || '未绑定'}}</text>
      </view>
    </view>
    <text class="edit-icon">✏️</text>
  </view>

  <!-- 数据统计 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.todoCount || 0}}</text>
      <text class="stat-label">待办事项</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.activityCount || 0}}</text>
      <text class="stat-label">参与活动</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.chatCount || 0}}</text>
      <text class="stat-label">AI对话</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToMyCourses">
      <view class="menu-left"><text class="menu-icon">📚</text><text>我的课程</text></view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMyActivities">
      <view class="menu-left"><text class="menu-icon">🎉</text><text>我的活动</text></view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMyFavorites">
      <view class="menu-left"><text class="menu-icon">❤️</text><text>我的收藏</text></view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMyFeedback">
      <view class="menu-left"><text class="menu-icon">💬</text><text>意见反馈</text></view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 系统设置 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToRecommendSettings">
      <view class="menu-left"><text class="menu-icon">🎯</text><text>推荐偏好设置</text></view>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <view class="menu-left"><text class="menu-icon">🗑️</text><text>清理缓存</text></view>
      <text>{{cacheSize}}MB ›</text>
    </view>
  </view>

  <!-- 其他 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="showAbout">
      <view class="menu-left"><text class="menu-icon">ℹ️</text><text>关于我们</text></view>
      <text class="arrow">›</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="logout">退出登录</button>
  <view class="version">版本 v1.0.0</view>
</view>