.timetable-container {
  height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 头部 */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.week-control {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.arrow-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #666;
}

.week-text {
  font-size: 32rpx;
  font-weight: bold;
}

.sync-btn {
  font-size: 26rpx;
  color: #4CAF50;
  padding: 10rpx 20rpx;
  background-color: #e8f5e9;
  border-radius: 40rpx;
}

/* 视图切换 */
.view-switch {
  display: flex;
  background-color: #f0f0f0;
  border-radius: 48rpx;
  padding: 6rpx;
  margin: 20rpx 30rpx;
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: #666;
}

.switch-item.active {
  background-color: #4CAF50;
  color: #fff;
}

/* ========== 周视图表格 ========== */
.week-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  background-color: #f5f5f5;
  border-bottom: 1rpx solid #eee;
}

.table-header .time-col {
  width: 140rpx;
  padding: 20rpx 0;
}

.table-header .day-col {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
}

.day-name {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}

.day-date {
  font-size: 22rpx;
  color: #999;
}

.table-body {
  flex: 1;
  height: calc(100vh - 300rpx);
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #eee;
  min-height: 100rpx;
}

.table-row .time-col {
  width: 140rpx;
  padding: 16rpx 0;
  text-align: center;
  background-color: #fafafa;
  font-size: 24rpx;
  color: #666;
}

.table-row .day-col {
  flex: 1;
  border-left: 1rpx solid #eee;
  padding: 8rpx;
}

.course-cell {
  height: 100%;
  min-height: 84rpx;
}

.course-card {
  background-color: #e8f5e9;
  border-radius: 8rpx;
  padding: 8rpx;
  margin: 4rpx;
}

.course-name {
  font-size: 24rpx;
  font-weight: 500;
  display: block;
  color: #333;
}

.course-location, .course-teacher {
  font-size: 20rpx;
  color: #666;
  display: block;
}

/* ========== 日视图 ========== */
.day-view {
  flex: 1;
  margin: 0 20rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.date-header {
  background-color: #f5f5f5;
  border-bottom: 1rpx solid #eee;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  font-size: 28rpx;
}

.day-schedule {
  height: calc(100vh - 300rpx);
}

.schedule-row {
  display: flex;
  border-bottom: 1rpx solid #eee;
  min-height: 100rpx;
}

.schedule-row .time-col {
  width: 160rpx;
  padding: 16rpx 0;
  text-align: center;
  background-color: #fafafa;
  font-size: 24rpx;
  color: #666;
}

.schedule-row .course-info {
  flex: 1;
  padding: 12rpx;
}

.empty-slot {
  color: #ccc;
  font-size: 24rpx;
  text-align: center;
  padding: 20rpx;
}

/* ========== 弹窗样式 ========== */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
  z-index: 1000;
}

.modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-content {
  width: 80%;
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
}

.modal-body {
  padding: 30rpx;
}

.info-row {
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.btn-reminder, .btn-delete, .btn-close {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
}

.btn-reminder {
  background-color: #4CAF50;
  color: #fff;
}

.btn-delete {
  background-color: #ff5252;
  color: #fff;
}

.btn-close {
  background-color: #f0f0f0;
  color: #666;
}