.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

.chat-history {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 30rpx;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.user .message-bubble {
  background-color: #4CAF50;
  color: #fff;
}

.message.assistant .message-bubble {
  background-color: #fff;
  color: #333;
}

.message-avatar {
  width: 70rpx;
  height: 70rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.message.user .message-avatar {
  margin-right: 0;
  margin-left: 16rpx;
  order: 2;
}

.avatar-emoji {
  width: 100%;
  height: 100%;
  background-color: #e0e0e0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  word-wrap: break-word;
}

.message-content {
  font-size: 30rpx;
  line-height: 1.5;
}

.message-source {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #eee;
}

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.typing-indicator span {
  width: 16rpx;
  height: 16rpx;
  background-color: #999;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
.typing-indicator span:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40% { transform: scale(1.2); opacity: 1; }
}

.suggestions {
  background-color: #fff;
  margin: 20rpx;
  border-radius: 24rpx;
  padding: 24rpx;
}

.suggestion-title {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.suggestion-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.suggestion-item {
  background-color: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #333;
}

.input-area {
  background-color: #fff;
  padding: 20rpx;
  border-top: 1rpx solid #eee;
}

.input-wrapper {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.message-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 48rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
}

.send-btn {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 48rpx;
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  margin: 0;
}