.filter-form {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.picker-value {
  background-color: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  min-width: 200rpx;
  text-align: center;
}

.btn-search {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.results {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
}

.result-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.result-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.room-name {
  font-size: 30rpx;
  font-weight: 500;
}

.room-info {
  font-size: 24rpx;
  color: #999;
}