/* pages/classroom/classroom.wxss */
/* Tab样式 */
.tabs {
  display: flex;
  background: #fff;
  border-bottom: 1px solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1px solid #f0f0f0;
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333;
}

.filter-item .arrow {
  margin-left: 10rpx;
  font-size: 24rpx;
  color: #999;
}

/* 高级筛选面板 */
.advanced-filter {
  background: #f8f8f8;
  padding: 30rpx;
  border-bottom: 1px solid #eee;
}

.filter-group {
  margin-bottom: 30rpx;
}

.filter-group .label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag {
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  border: 1px solid #ddd;
}

.tag.active {
  background: #07c160;
  color: #fff;
  border-color: #07c160;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.reset-btn, .confirm-btn {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.reset-btn {
  background: #fff;
  color: #666;
  border: 1px solid #ddd;
}

.confirm-btn {
  background: #07c160;
  color: #fff;
}

/* 教室列表 */
.classroom-list {
  height: calc(100vh - 200rpx);
}

.classroom-item {
  background: #fff;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.room-info {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.room-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.room-type {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.room-details {
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.room-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.favorite-btn, .todo-btn {
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 活动筛选 */
.activity-filter {
  background: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1px solid #eee;
}

.search-input {
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.type-tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.type-tab {
  display: inline-block;
  padding: 10rpx 30rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 40rpx;
  background: #f5f5f5;
}

.type-tab.active {
  background: #07c160;
  color: #fff;
}

.time-filter {
  display: flex;
  gap: 20rpx;
}

.picker-btn {
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

/* 活动列表 */
.activity-list {
  height: calc(100vh - 300rpx);
}

.activity-item {
  background: #fff;
  margin: 20rpx 30rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.activity-type {
  font-size: 24rpx;
  color: #07c160;
  background: #e8f8f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.activity-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}

.activity-stats {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #999;
}

.status {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.status.sign_up {
  background: #e8f8f0;
  color: #07c160;
}

.status.ongoing {
  background: #e8f0fe;
  color: #1989fa;
}

.status.ended {
  background: #f5f5f5;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
}

.empty-state .tip {
  display: block;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}