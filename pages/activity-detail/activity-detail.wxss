.container {
  padding: 0;
}

.detail-cover-placeholder {
  width: 100%;
  height: 400rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
}

.detail-content {
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -20rpx;
  padding: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.info-list {
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #eee;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  width: 120rpx;
  color: #666;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.description {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 40rpx;
  background-color: #fff;
}

.btn-favorite, .btn-register, .btn-disabled {
  flex: 1;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.btn-favorite {
  background-color: #f5f5f5;
  color: #333;
}

.btn-register {
  background-color: #4CAF50;
  color: #fff;
}

.btn-disabled {
  background-color: #ccc;
  color: #fff;
}