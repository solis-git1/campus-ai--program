<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.mapper.TaskReminderMapper">

    <select id="getById" resultType="com.campus.entity.TaskReminder">
        select * from task_reminder where reminder_id = #{reminderId}
    </select>

    <select id="getByTaskId" resultType="com.campus.entity.TaskReminder">
        select * from task_reminder where task_id = #{taskId}
    </select>

    <select id="listByTaskId" resultType="com.campus.entity.TaskReminder">
        select * from task_reminder where task_id = #{taskId}
    </select>

    <select id="listNeedSend" resultType="com.campus.entity.TaskReminder">
        select * from task_reminder where remind_time &lt;= now() and send_count &lt; 3
    </select>

    <insert id="insert">
        insert into task_reminder(task_id, remind_time) values(#{taskId}, #{remindTime})
    </insert>

    <update id="update">
        update task_reminder
        <set>
            <if test="remindTime != null">remind_time = #{remindTime},</if>
        </set>
        where reminder_id = #{reminderId}
    </update>

    <update id="updateSend">
        update task_reminder set send_count = send_count +1, last_send_time = now() where reminder_id = #{reminderId}
    </update>

    <delete id="deleteById">
        delete from task_reminder where reminder_id = #{reminderId}
    </delete>

    <delete id="deleteByTaskId">
        delete from task_reminder where task_id = #{taskId}
    </delete>

</mapper>
